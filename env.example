# ─────────────────────────────────────────────────────────────────────────────
# sim24 Auto Booker — Environment Variables
# Copy this to .env for local testing (NEVER commit .env to git)
# These same variables must be added to GitHub Actions Secrets
# ─────────────────────────────────────────────────────────────────────────────

# ── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here        # From @BotFather
TELEGRAM_CHAT_ID=your_chat_id_here            # From @userinfobot

# ── sim24 Credentials ────────────────────────────────────────────────────────
SIM24_USERNAME=your_username_or_phone_number  # Benutzername or Rufnummer
SIM24_PASSWORD=your_online_password           # Online-Passwort

# ── Browser (local only) ──────────────────────────────────────────────────────
# Set to true to use your local Microsoft Edge instead of Playwright's Chromium
# Leave as false (or remove) on GitHub Actions — Edge is not available there
USE_EDGE=true
