# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
.venv/
env/
ENV/

# Local environment files (keep template tracked)
.env
.env.*
!.env.example

# Python tooling caches and test artifacts
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.hypothesis/
.coverage
.coverage.*
htmlcov/

# Build and packaging artifacts
build/
dist/
.eggs/
*.egg-info/
*.egg
pip-wheel-metadata/
site/

# Notebook and interactive artifacts
.ipynb_checkpoints/

# IDE/editor settings
.vscode/
.idea/

# OS generated files
.DS_Store
Thumbs.db

# Logs and runtime artifacts
*.log
*.pid

# Python version manager / local tool state
.python-version

# Local repository mirror/artifacts
repo-mirror.git/

# Wrangler local dev secrets (contains real credentials — NEVER commit)
cloudflare_trigger/.dev.vars

# Wrangler local dev state/cache (generated at runtime)
cloudflare_trigger/.wrangler/
